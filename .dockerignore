# Root-level .dockerignore (applies when context is the repo root)
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ─────────────────────────────────────────────────────────────
**/node_modules
.pnpm-store

# ── Build outputs ─────────────────────────────────────────────────────────────
**/.next/
**/dist/
**/out/
**/*.tsbuildinfo

# ── Turbo ────────────────────────────────────────────────────────────────────
**/.turbo/

# ── Secrets / env ────────────────────────────────────────────────────────────
.env
.env.local
**/.env.local
**/.env.*.local

# ── Local databases ───────────────────────────────────────────────────────────
**/dev.db
**/dev.db-shm
**/dev.db-wal

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Git ──────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Tests ────────────────────────────────────────────────────────────────────
**/coverage/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
