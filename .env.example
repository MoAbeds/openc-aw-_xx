# ─────────────────────────────────────────────
#  apex-os · Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values.

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Next.js (apps/web) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── API (apps/api) ───────────────────────────
API_PORT=4000
API_HOST=0.0.0.0

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/apex_os

# ── Auth / JWT ───────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-here-123
JWT_EXPIRES_IN=7d

# ── External Services ────────────────────────
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
